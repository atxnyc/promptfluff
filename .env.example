# promptfluff environment template. Copy to `.env` for local dev (gitignored).
#
# The RudderStack values below are CLIENT-SIDE write keys, not secrets: the web
# write key ships in the landing page HTML, and the HTTP-source write key ships
# in the published CLI/hook. They are listed here only so the analytics config
# lives in one discoverable place. See docs/analytics.md.

# --- RudderStack: web JavaScript source (site/index.html snippet) ---
RUDDERSTACK_WEB_WRITE_KEY=3F5Q1sTPz70dSsb3js5xT89zT43

# --- RudderStack: HTTP source (CLI installer + hook heartbeat) ---
# Source ID:  3F5Q5LJJ4ESEwpH9veXC9hhtpVe
# Override the baked-in defaults in src/telemetry.js with these if needed.
PROMPTFLUFF_RUDDERSTACK_WRITE_KEY=3F5Q5IN7aO1QR8yqrInShrQtdnu
PROMPTFLUFF_RUDDERSTACK_DATA_PLANE=https://opascopeanajoo.dataplane.rudderstack.com

# --- Telemetry opt-out (any one of these disables the HTTP-source telemetry) ---
# DO_NOT_TRACK=1
# PROMPTFLUFF_NO_ANALYTICS=1
# PROMPTFLUFF_TELEMETRY=off

# Other project secrets (do NOT commit real values; keep them in .env only).
# OPENROUTER_API_KEY=
